<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>Tumpa Mail</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>XPC!</string>
	<key>CFBundleShortVersionString</key>
	<string>0.0.1</string>
	<key>CFBundleVersion</key>
	<string>2</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<!--
	    MailKit declaration. Apple Mail's extension point identifier
	    is `com.apple.email.extension` (NOT `com.apple.mail.extension`
	    — that one looks plausible but is wrong; verified by reading
	    the NSExtensionSDK block in
	    `/System/Library/Frameworks/MailKit.framework/Resources/Info.plist`).

	    MEExtensionCapabilities is the list of MailKit handler
	    protocols this extension implements. Mail will not list the
	    extension in its Settings → Extensions UI without this array
	    (verified against the
	    `Mail Extension.xctemplate/TemplateInfo.plist` in Xcode).

	    We declare MEMessageSecurityHandler — that's the
	    sign/encrypt outgoing + decrypt/verify incoming bundle
	    Phases 2/3 implement.
	-->
	<key>NSExtension</key>
	<dict>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.email.extension</string>
		<key>NSExtensionPrincipalClass</key>
		<string>$(PRODUCT_MODULE_NAME).TumpaMailExtension</string>
		<key>NSExtensionAttributes</key>
		<dict>
			<key>MEMessageSecurity</key>
			<dict>
				<key>MEMessageSecurityIcon</key>
				<string>ShieldIcon</string>
			</dict>
			<key>MEExtensionCapabilities</key>
			<array>
				<string>MEMessageSecurityHandler</string>
			</array>
		</dict>
	</dict>
</dict>
</plist>
